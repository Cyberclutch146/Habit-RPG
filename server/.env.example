# Express Server Port
PORT=5000

# OTP Hash Secret (Generate a strong random string)
OTP_SECRET=your_super_secret_otp_hmac_key

# JWT Token Secret
JWT_SECRET=your_super_secret_jwt_key

# Nodemailer / Gmail SMTP Settings
# Generate a Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM='"Habit RPG Command" <your_email@gmail.com>'

# Firebase Admin SDK (Optional: Provide path to service account if needed, typically uses GOOGLE_APPLICATION_CREDENTIALS)
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
# FIREBASE_PROJECT_ID=your_project_id
